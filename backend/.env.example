# Copy to .env and fill in values

PORT=8080
NODE_ENV=development

# PostgreSQL
# DB_URL is what the app (src/utils/db.js) and migrations (npm run migrate) read.
# Keep it in sync with DB_URL below.
DB_URL=postgres://postgres:postgres@localhost:5432/airgead
PGHOST=localhost
PGPORT=5432
PGDATABASE=airgead
PGUSER=postgres
PGPASSWORD=postgres

# Auth
JWT_SECRET=change-me-in-production

# Where the frontend lives (Stripe redirect targets, verification links).
FRONTEND_URL=http://localhost:3000

# Security hardening (Phase 6).
# Comma-separated browser origins allowed by CORS. Unset = permissive (dev
# only). Production MUST set it to the frontend origin.
# CORS_ORIGINS=https://app.example.com
#
# Self-serve signups must verify their email (7-day login grace; invite-link
# signups are auto-verified). Set to false to disable in dev.
REQUIRE_EMAIL_VERIFICATION=true

# Error reporting (Phase 6 ops). Unset = Sentry never loaded.
# SENTRY_DSN=https://…@…ingest.sentry.io/…

# Billing (built but NOT enforced by default).
#   BILLING_ENFORCED=false -> everything free-and-open (the pre-GA default);
#                             trial/payment reminder emails are also silent.
#   BILLING_ENFORCED=true  -> expired orgs become read-only: writes on
#                             /expenses, /receipts and /assets answer 402 until
#                             the org subscribes (or is a practice, or an
#                             unexpired trial). The daily reminder job also runs.
# Commercial model: accountancy practices are FREE (once approved); their
# CLIENTS pay for themselves, exactly like a solo org (14-day trial -> monthly).
BILLING_ENFORCED=true
# Stripe stays completely inert while STRIPE_SECRET_KEY is unset: billing
# routes answer 502 "not configured".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price id from the Stripe dashboard (recurring, monthly). Every paying org - a
# solo/business or a practice's client - subscribes at this one price.
STRIPE_PRICE_SOLO=

# Where new accountancy-practice applications are emailed for review. Falls back
# to the SMTP user / support inbox when unset.
# PRACTICE_APPLICATIONS_EMAIL=admin@airgead.com

# Sage Business Cloud Accounting export (feature-flagged, default OFF).
#   SAGE_ENABLED=false -> all /sage routes and the accountant Sage export 404.
#   SAGE_ENABLED=true  -> accountancy practices can link Sage in Settings and
#                         export client transactions as other_payments/receipts.
# Stays completely inert without credentials: routes answer 502 "not configured".
SAGE_ENABLED=false
# OAuth app credentials from developer.sage.com. The app's registered redirect
# URI must be ${PUBLIC_BACKEND_URL}/sage/callback.
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=
# 32-byte hex key for AES-256-GCM encryption of stored Sage OAuth tokens.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Email (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@airgead.com

# Receipt image storage
#   STORAGE_DRIVER=local  -> write to LOCAL_STORAGE_DIR on disk (default; no
#                            cloud creds needed). Reads are served via signed
#                            /files/<token> URLs (PUBLIC_BACKEND_URL must be
#                            reachable by the browser).
#   STORAGE_DRIVER=gcs    -> Google Cloud Storage (private objects + V4 signed
#                            URLs); requires the GOOGLE_* vars below.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=temp/receipts
PUBLIC_BACKEND_URL=http://localhost:8080

# Google Cloud Storage (only when STORAGE_DRIVER=gcs)
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_PROJECT_ID=
# Local dev: path to a downloaded service-account key file.
GOOGLE_APPLICATION_CREDENTIALS=sa-key.json
# Hosted (Railway, etc.) with no filesystem for a key file: paste the entire
# service-account key JSON here instead. Takes precedence over the path above.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Receipt OCR (Phase 2 - built but DORMANT; do NOT enable in production yet).
#   OCR_PROVIDER=none    -> OCR fully disabled. /receipts/process only cleans +
#                           stores the image; no provider is constructed or
#                           called. This is the shipping default.
#   OCR_PROVIDER=mock    -> MockOcrProvider (canned data, no real OCR / no cost).
#                           For exercising the dormant auto-fill path locally.
#   OCR_PROVIDER=hosted  -> HostedOcrProvider (throws NotImplemented until a
#                           vendor is wired; EU data residency required).
OCR_PROVIDER=none
# Frontend-readable mirror (see NEXT_PUBLIC_OCR_AUTOFILL_ENABLED in the frontend
# env). When false, the capture flow goes straight to the manual form - the form
# never requests or renders OCR auto-fill. Keep false until OCR is validated.
OCR_AUTOFILL_ENABLED=false
