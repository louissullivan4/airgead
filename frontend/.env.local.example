# Copy to .env.local and fill in values

# URL of the backend API, as seen from the browser
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL of the backend API, as seen from inside docker (used for server-side rewrites)
BACKEND_URL=http://backend:8080

# Phase 2 OCR auto-fill feature flag (DORMANT). Leave false: the camera capture
# flow goes straight to the manual form and no OCR auto-fill UI renders. Only set
# to true to exercise the dormant auto-fill path (also needs the backend's
# OCR_PROVIDER=mock). Keep false until OCR is validated.
NEXT_PUBLIC_OCR_AUTOFILL_ENABLED=false
